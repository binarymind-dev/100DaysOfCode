// Day 004 - Arrays in C++
// 100 Days of Code Challenge

#include <iostream>
using namespace std;

int main() {
    // Array declare
    int numbers[5] = {10, 20, 30, 40, 50};

    cout << "=== Array Elements ===" << endl;

    // Array print 
    for (int i = 0; i < 5; i++) {
        cout << "numbers[" << i << "] = " << numbers[i] << endl;
    }

    // Sum 
    int sum = 0;
    for (int i = 0; i < 5; i++) {
        sum += numbers[i];
    }
    cout << "\nSum = " << sum << endl;
    cout << "Average = " << sum / 5.0 << endl;

    // Max element 
    int max = numbers[0];
    for (int i = 1; i < 5; i++) {
        if (numbers[i] > max) {
            max = numbers[i];
        }
    }
    cout << "Maximum = " << max << endl;

    return 0;
}
